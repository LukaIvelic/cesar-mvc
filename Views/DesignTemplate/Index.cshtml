@model IEnumerable<cesar.Features.DesignTemplates.Models.DesignTemplateViewModel>

@{
    var columns = new[] { "ID", "Name", "Content Type", "Placeholder Schema", "Preview", "Actions" };
}

<div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold">Design Templates</h2>
        <a asp-action="Create" class="bg-black text-white text-sm px-4 py-2 rounded hover:bg-neutral-800 transition">
            + Add Template
        </a>
    </div>

    <table class="w-full border-collapse">
        <thead>
            <tr>
                @foreach (var col in columns)
                {
                    <th class="bg-[#efefef] border border-[#d0d0d0] px-4 py-2 text-left text-sm font-semibold">@col</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var template in Model)
            {
                <tr class="align-top">
                    <td class="bg-[#fafafa] border border-[#d0d0d0] px-4 py-3 text-sm">@template.Id</td>
                    <td class="bg-[#fafafa] border border-[#d0d0d0] px-4 py-3 text-sm font-medium">@template.Name</td>
                    <td class="bg-[#fafafa] border border-[#d0d0d0] px-4 py-3 text-sm">@template.ContentType</td>
                    <td class="bg-[#fafafa] border border-[#d0d0d0] px-4 py-3 text-xs font-mono whitespace-pre-wrap max-w-sm">@template.PlaceholderSchema</td>
                    <td class="bg-[#fafafa] border border-[#d0d0d0] px-4 py-3 text-sm">
                        <a asp-action="Preview" asp-route-id="@template.Id" class="text-blue-600 hover:underline">Open preview</a>
                    </td>
                    <td class="bg-[#fafafa] border border-[#d0d0d0] px-4 py-3 text-sm">
                        <div class="flex flex-col gap-2">
                            <a asp-action="Preview" asp-route-id="@template.Id" class="text-blue-600 hover:underline">Preview</a>
                            <a asp-action="Edit" asp-route-id="@template.Id" class="text-neutral-600 hover:underline">Edit</a>
                            <form asp-action="Delete" asp-route-id="@template.Id" method="post" onsubmit="return confirm('Soft delete this template?')">
                                <button type="submit" class="text-red-500 hover:underline">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
