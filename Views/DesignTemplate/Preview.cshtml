@model cesar.Features.DesignTemplates.Models.PreviewDesignTemplateModel
@using System.Text.Json

<div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold">Preview — @Model.Name</h2>
        <a asp-action="Index" class="text-sm text-neutral-500 hover:underline">← Back to list</a>
    </div>

    <div class="mb-6 bg-[#fafafa] border border-[#d0d0d0] rounded p-4 text-sm grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
            <span class="text-neutral-500">Template ID</span>
            <p class="font-medium">@Model.Id</p>
        </div>
        <div>
            <span class="text-neutral-500">Name</span>
            <p class="font-medium">@Model.Name</p>
        </div>
        <div>
            <span class="text-neutral-500">Content Type</span>
            <p class="font-medium">@Model.ContentType</p>
        </div>
    </div>

    <form asp-action="Preview" asp-route-id="@Model.Id" method="post" class="grid grid-cols-1 gap-8">
        <div class="flex flex-col gap-4">
            <div>
                <label class="block text-sm font-medium mb-1">Use Raw Lead JSON</label>
                <div class="flex gap-2">
                    <select id="raw-json-select" class="w-full border border-[#d0d0d0] rounded px-3 py-2 text-sm focus:outline-none focus:border-black">
                        <option value="">Select lead JSON</option>
                        @foreach (var option in Model.RawJsonOptions)
                        {
                            <option value="@option.Id">@option.Label</option>
                        }
                    </select>
                    <button id="inject-json-btn" type="button" class="border border-[#d0d0d0] px-3 py-2 rounded text-sm hover:bg-neutral-100">Inject</button>
                </div>
            </div>

            <div>
                <label asp-for="PreviewRawJsonData" class="block text-sm font-medium mb-1">Preview Raw JSON</label>
                <textarea asp-for="PreviewRawJsonData" rows="16" class="w-full border border-[#d0d0d0] rounded px-3 py-2 text-sm font-mono focus:outline-none focus:border-black resize-y"></textarea>
                <span asp-validation-for="PreviewRawJsonData" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div class="flex gap-3">
                <button type="submit" class="bg-black text-white text-sm px-4 py-2 rounded hover:bg-neutral-800 transition">Render Preview</button>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="border border-[#d0d0d0] text-sm px-4 py-2 rounded hover:bg-neutral-100 transition">Edit Template</a>
            </div>

            <p class="text-sm text-neutral-500 mb-2">Rendered HTML</p>
            <div id="injected-preview" class="border border-[#d0d0d0] rounded bg-white p-4 min-h-[420px] overflow-auto">
                @Html.Raw(Model.RenderedHtml)
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        (function () {
            const payload = @Html.Raw(JsonSerializer.Serialize(Model.RawJsonOptions.ToDictionary(x => x.Id.ToString(), x => x.RawJsonData)));
            const templateMarkup = @Html.Raw(JsonSerializer.Serialize(Model.HtmlMarkup));
            const select = document.getElementById('raw-json-select');
            const button = document.getElementById('inject-json-btn');
            const target = document.getElementById('PreviewRawJsonData');
            const preview = document.getElementById('injected-preview');

            function getCaseInsensitive(obj, key) {
                if (!obj || typeof obj !== 'object') return undefined;
                const exact = obj[key];
                if (exact !== undefined) return exact;
                const foundKey = Object.keys(obj).find(k => k.toLowerCase() === key.toLowerCase());
                return foundKey ? obj[foundKey] : undefined;
            }

            function resolvePath(source, path) {
                return path.split('.').reduce((acc, part) => getCaseInsensitive(acc, part), source);
            }

            function renderPreview() {
                if (!preview || !target) return;

                let data;
                try {
                    data = JSON.parse(target.value || '{}');
                } catch {
                    preview.textContent = 'Invalid JSON in Preview Raw JSON.';
                    return;
                }

                const rendered = (templateMarkup || '').replace(/{{\s*([a-zA-Z0-9_.]+)\s*}}/g, function (match, path) {
                    const value = resolvePath(data, path);
                    return value === undefined || value === null ? match : String(value);
                });

                preview.innerHTML = rendered;
            }

            button.addEventListener('click', function () {
                const key = select.value;
                if (!key || !payload[key] || !target) return;
                target.value = payload[key];
                renderPreview();
            });

            target.addEventListener('input', renderPreview);
        })();
    </script>
}
