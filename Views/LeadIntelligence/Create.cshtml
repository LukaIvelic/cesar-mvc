@model cesar.Features.LeadIntelligence.Models.CreateLeadIntelligenceModel

<div class="max-w-xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold">Add Intelligence Record</h2>
        <a asp-action="Index" class="text-sm text-neutral-500 hover:underline">← Back to list</a>
    </div>

    <form asp-action="Create" method="post" class="flex flex-col gap-8">
        <div>
            <label asp-for="LeadId" class="block text-sm font-medium mb-1">Lead ID</label>
            <input asp-for="LeadId" type="number" class="w-full border border-[#d0d0d0] rounded px-3 py-2 text-sm focus:outline-none focus:border-black" />
            <span asp-validation-for="LeadId" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="ContentHash" class="block text-sm font-medium mb-1">Content Hash (SHA256)</label>
            <input asp-for="ContentHash" class="w-full border border-[#d0d0d0] rounded px-3 py-2 text-sm font-mono focus:outline-none focus:border-black" placeholder="e.g. a3f1c2..." />
            <span asp-validation-for="ContentHash" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="FamiliarityIndex" class="block text-sm font-medium mb-1">Familiarity Index <span class="text-neutral-400 font-normal">(0–1)</span></label>
            <input asp-for="FamiliarityIndex" type="number" step="0.001" min="0" max="1" class="w-full border border-[#d0d0d0] rounded px-3 py-2 text-sm focus:outline-none focus:border-black" />
            <span asp-validation-for="FamiliarityIndex" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="DataDensityScore" class="block text-sm font-medium mb-1">Data Density Score <span class="text-neutral-400 font-normal">(0–1)</span></label>
            <input asp-for="DataDensityScore" type="number" step="0.001" min="0" max="1" class="w-full border border-[#d0d0d0] rounded px-3 py-2 text-sm focus:outline-none focus:border-black" />
            <span asp-validation-for="DataDensityScore" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <button type="submit" class="bg-black text-white text-sm px-4 py-2 rounded hover:bg-neutral-800 transition self-start">
            Save Record
        </button>
    </form>
</div>
