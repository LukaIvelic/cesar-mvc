@model IEnumerable<cesar.Features.JsonKeyStats.Models.JsonKeyStatViewModel>

@{
    var columns = new[] { "ID", "Key", "Occurrences", "Tracked Since", "Actions" };
}

<div class="max-w-4xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold">JSON Key Stats</h2>
        <a asp-action="Create" class="bg-black text-white text-sm px-4 py-2 rounded hover:bg-neutral-800 transition">
            + Add Key
        </a>
    </div>

    <table class="w-full border-collapse">
        <thead>
            <tr>
                @foreach (var col in columns)
                {
                    <th class="bg-[#efefef] border border-[#d0d0d0] px-4 py-2 text-left text-sm font-semibold">@col</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var stat in Model)
            {
                <tr>
                    <td class="bg-[#fafafa] border border-[#d0d0d0] px-4 py-2 text-sm">@stat.Id</td>
                    <td class="bg-[#fafafa] border border-[#d0d0d0] px-4 py-2 text-sm font-mono">@stat.Key</td>
                    <td class="bg-[#fafafa] border border-[#d0d0d0] px-4 py-2 text-sm font-semibold">@stat.Occurrences</td>
                    <td class="bg-[#fafafa] border border-[#d0d0d0] px-4 py-2 text-sm">@stat.ValidFrom.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="bg-[#fafafa] border border-[#d0d0d0] px-4 py-2 text-sm">
                        <div class="flex gap-3">
                            <a asp-action="Edit" asp-route-id="@stat.Id" class="text-neutral-600 hover:underline">Edit</a>
                            <form asp-action="Delete" asp-route-id="@stat.Id" method="post" onsubmit="return confirm('Soft delete this key?')">
                                <button type="submit" class="text-red-500 hover:underline">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
